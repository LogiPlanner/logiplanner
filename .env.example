# Example .env file for LogiPlanner
# Copy this file to `.env` and fill in your actual secrets/keys

# App
PROJECT_NAME=LogiPlanner
API_V1_STR=/api/v1
DEBUG=True
BASE_URL=http://127.0.0.1:8000

# Database
DATABASE_URL=postgresql+psycopg2://postgres:reyazreyaz@localhost:5432/logiplanner

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@logiplanner.com

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# RAG / AI Brain
OPENAI_API_KEY=
